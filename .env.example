# Copy to .env and fill in local secrets.
# .env is gitignored; this example file is safe to track.

export PROXMOX_VE_ENDPOINT="https://proxmox.example.internal:8006/"
export PROXMOX_VE_API_TOKEN="terraform@pve!provider=REPLACE_WITH_PROXMOX_TOKEN"

# SSH/bootstrap targets.
export PVE_HOST="proxmox.example.internal"
export SERVER_NAME="dns-ui.example.internal"

# Optional second Caddy vhost for Forgejo.
export FORGEJO_SERVER_NAME="git.example.internal"
export FORGEJO_UPSTREAM="192.0.2.62:3000"

# Cloudflare credentials used by Caddy DNS-01 on the Technitium LXC.
export CF_API_EMAIL="REPLACE_WITH_CLOUDFLARE_EMAIL"
export CF_DNS_API_TOKEN="REPLACE_WITH_CLOUDFLARE_DNS_TOKEN"

# Used as Terraform variables for the LXC root account.
export TF_VAR_container_root_password="REPLACE_WITH_A_LONG_RANDOM_PASSWORD"
export TF_VAR_container_ssh_public_keys='["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA_REPLACE_ME user@host"]'

# Used once to create a persistent Technitium API token from the CLI.
export TECHNITIUM_ADMIN_USER="admin"
export TECHNITIUM_ADMIN_PASS="REPLACE_WITH_TECHNITIUM_ADMIN_PASSWORD"

# Filled after token creation; used by Terraform's Technitium API script.
export TF_VAR_technitium_api_token="REPLACE_AFTER_TOKEN_CREATION"

# Optional Forgejo bootstrap values.
export FORGEJO_VERSION="REPLACE_WITH_FORGEJO_VERSION"
export FORGEJO_DOMAIN="git.example.internal"
