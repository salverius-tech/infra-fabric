[Unit]
Description=Hermes Agent Gateway - Messaging Platform Integration
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User={{ hermes_runtime_user | default('anvil') }}
Group={{ hermes_runtime_user | default('anvil') }}
ExecStart=/usr/local/lib/hermes-agent/venv/bin/python -m hermes_cli.main gateway run
WorkingDirectory=/home/{{ hermes_runtime_user | default('anvil') }}/.hermes
Environment="HOME=/home/{{ hermes_runtime_user | default('anvil') }}"
Environment="USER={{ hermes_runtime_user | default('anvil') }}"
Environment="LOGNAME={{ hermes_runtime_user | default('anvil') }}"
Environment="PATH=/usr/local/lib/hermes-agent/venv/bin:/usr/local/lib/hermes-node/current/bin:/home/{{ hermes_runtime_user | default('anvil') }}/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="VIRTUAL_ENV=/usr/local/lib/hermes-agent/venv"
Environment="HERMES_HOME=/home/{{ hermes_runtime_user | default('anvil') }}/.hermes"
Environment="HERMES_OPERATOR_REPO_PATH={{ hermes_repo_path | default('/srv/homelab-infra') }}"
Environment="HERMES_DISABLE_LAZY_INSTALLS=1"
Restart=always
RestartSec=5
RestartForceExitStatus=75
KillMode=mixed
KillSignal=SIGTERM
ExecReload=/bin/kill -USR1 $MAINPID
ExecStopPost=-/usr/local/lib/hermes-agent/venv/bin/python -m gateway.cgroup_cleanup
TimeoutStopSec=90
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
