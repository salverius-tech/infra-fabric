{
    email {{ caddy_email }}
}

{{ caddy_server_name }} {
    encode zstd gzip
    reverse_proxy {{ caddy_upstream }}

    tls {
        dns cloudflare {env.CF_DNS_API_TOKEN}
        resolvers 1.1.1.1
    }
}
{% for vhost in caddy_extra_vhosts | default([]) %}

{{ vhost.server_name }} {
    encode zstd gzip
    reverse_proxy {{ vhost.upstream }}

    tls {
        dns cloudflare {env.CF_DNS_API_TOKEN}
        resolvers 1.1.1.1
    }
}
{% endfor %}
