services:
  db:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: {{ infisical_postgres_user | default('infisical') }}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: {{ infisical_postgres_db | default('infisical') }}
    volumes:
      - {{ infisical_data_dir | default('/var/lib/infisical') }}/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ infisical_postgres_user | default('infisical') }} -d {{ infisical_postgres_db | default('infisical') }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - {{ infisical_data_dir | default('/var/lib/infisical') }}/redis:/data

  infisical:
    image: infisical/infisical:{{ infisical_version | default('v0.162.3@sha256:75e74ee1cc11bdc1b504acb9846940484501ce3f1c54cb3af77cdd09a6c05893') }}
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_started
    env_file:
      - /etc/infisical/infisical.env
    ports:
      - "127.0.0.1:8080:8080"
