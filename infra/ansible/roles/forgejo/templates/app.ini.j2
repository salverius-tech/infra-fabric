APP_NAME = Forgejo
RUN_USER = git
WORK_PATH = /var/lib/forgejo

[database]
{% if forgejo_database.type | default('sqlite') == 'postgres' %}
DB_TYPE = postgres
HOST = {{ forgejo_database.host | default('127.0.0.1') }}:{{ forgejo_database.port | default(5432) }}
NAME = {{ forgejo_database.name | default('forgejo') }}
USER = {{ forgejo_database.user | default('forgejo') }}
PASSWD = {{ forgejo_postgres_password }}
SSL_MODE = {{ forgejo_database.ssl_mode | default('disable') }}
{% else %}
DB_TYPE = sqlite3
PATH = /var/lib/forgejo/data/forgejo.db
{% endif %}

[repository]
ROOT = /var/lib/forgejo/data/gitea-repositories

[server]
DOMAIN = {{ forgejo_domain }}
ROOT_URL = {{ forgejo_root_url | default('https://' ~ forgejo_domain ~ '/') }}
HTTP_ADDR = 127.0.0.1
HTTP_PORT = 3000
SSH_DOMAIN = {{ forgejo_domain }}
SSH_PORT = {{ forgejo_ssh_port | default(22) }}
SSH_USER = git
START_SSH_SERVER = false
LFS_JWT_SECRET = {{ forgejo_lfs_jwt_secret }}

[security]
INSTALL_LOCK = true
SECRET_KEY = {{ forgejo_secret_key }}
INTERNAL_TOKEN = {{ forgejo_internal_token }}

[oauth2]
JWT_SECRET = {{ forgejo_oauth2_jwt_secret }}

[actions]
ENABLED = {{ forgejo_actions_enabled | default(true) | bool | lower }}
DEFAULT_ACTIONS_URL = {{ forgejo_actions_default_url | default('https://data.forgejo.org') }}

[log]
MODE = file
LEVEL = Info
ROOT_PATH = /var/lib/forgejo/log
