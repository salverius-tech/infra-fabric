{
  "default_services": [
    "technitium",
    "forgejo"
  ],
  "services": {
    "technitium": {
      "state_capable": true,
      "state_order": 3,
      "terraform_addresses": [
        "module.technitium_dns[",
        "module.technitium_dns_vm["
      ],
      "terraform_replace_addresses": {
        "lxc": ["module.technitium_dns[0].proxmox_virtual_environment_container.this"],
        "vm": ["module.technitium_dns_vm[0].proxmox_virtual_environment_vm.this"]
      },
      "playbooks": [
        "infra/ansible/playbooks/technitium.yml",
        "infra/ansible/playbooks/caddy-proxy.yml",
        "infra/ansible/playbooks/technitium-dns.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "technitium_dns",
        "group": "technitium",
        "vmid_var": "technitium_vmid",
        "tf_vmid": "technitium_container_vmid",
        "tf_host": "technitium_container_ipv4_address"
      }
    },
    "forgejo": {
      "state_capable": true,
      "state_order": 2,
      "terraform_addresses": [
        "module.forgejo[",
        "module.forgejo_vm[",
        "terraform_data.forgejo_storage_validation["
      ],
      "terraform_replace_addresses": {
        "lxc": ["module.forgejo[0].proxmox_virtual_environment_container.this"],
        "vm": ["module.forgejo_vm[0].proxmox_virtual_environment_vm.this"]
      },
      "playbooks": [
        "infra/ansible/playbooks/forgejo.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "forgejo_lxc",
        "group": "forgejo",
        "vmid_var": "forgejo_vmid",
        "tf_vmid": "forgejo_container_vmid",
        "tf_host": "forgejo_lan_ip",
        "domain_var": "forgejo_domain",
        "tf_domain": "forgejo_server_name",
        "user_var": "forgejo_ansible_user",
        "tf_user": "forgejo_vm_cloud_init_user",
        "tf_user_runtime": "vm",
        "extra_play_vars": {
          "forgejo_database": "forgejo_database"
        }
      }
    },
    "tailscale_client": {
      "state_capable": false,
      "terraform_addresses": [
        "module.tailscale_client[",
        "module.tailscale_client_vm["
      ],
      "terraform_replace_addresses": {
        "lxc": ["module.tailscale_client[0].proxmox_virtual_environment_container.this"],
        "vm": ["module.tailscale_client_vm[0].proxmox_virtual_environment_vm.this"]
      },
      "playbooks": [
        "infra/ansible/playbooks/tailscale-client.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "tailscale_client",
        "group": "tailscale_client",
        "vmid_var": "tailscale_client_vmid",
        "tf_vmid": "tailscale_client_vmid",
        "tf_host": "tailscale_client_ipv4_address",
        "extra_play_vars": {
          "tailscale_client_enabled": "tailscale_client_enabled"
        }
      }
    },
    "forgejo_runner": {
      "state_capable": false,
      "terraform_addresses": [
        "module.forgejo_runner[",
        "module.forgejo_runner_vm["
      ],
      "terraform_replace_addresses": {
        "lxc": ["module.forgejo_runner[0].proxmox_virtual_environment_container.this"],
        "vm": ["module.forgejo_runner_vm[0].proxmox_virtual_environment_vm.this"]
      },
      "playbooks": [
        "infra/ansible/playbooks/forgejo-runner.yml"
      ],
      "dependencies": [
        "forgejo"
      ],
      "inventory": {
        "host": "forgejo_runner_lxc",
        "group": "forgejo_runner",
        "vmid_var": "forgejo_runner_vmid",
        "tf_vmid": "forgejo_runner_vmid",
        "tf_host": "forgejo_runner_ipv4_address"
      }
    },
    "infisical": {
      "state_capable": true,
      "state_order": 5,
      "terraform_addresses": [
        "module.infisical[",
        "module.infisical_vm["
      ],
      "terraform_replace_addresses": {
        "lxc": ["module.infisical[0].proxmox_virtual_environment_container.this"],
        "vm": ["module.infisical_vm[0].proxmox_virtual_environment_vm.this"]
      },
      "playbooks": [
        "infra/ansible/playbooks/infisical.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "infisical_lxc",
        "group": "infisical",
        "vmid_var": "infisical_vmid",
        "tf_vmid": "infisical_container_vmid",
        "tf_host": "infisical_lan_ip",
        "domain_var": "infisical_domain",
        "tf_domain": "infisical_server_name"
      }
    },
    "infisical_onramp": {
      "state_capable": true,
      "state_order": 5,
      "terraform_addresses": [
        "proxmox_virtual_environment_vm.onramp_host["
      ],
      "playbooks": [
        "infra/ansible/playbooks/infisical-onramp.yml"
      ],
      "dependencies": [
        "onramp_host"
      ],
      "inventory": {
        "host": "onramp_host_vm",
        "group": "onramp_host",
        "vmid_var": "onramp_host_vmid",
        "tf_vmid": "onramp_host_vmid",
        "tf_host": "onramp_host_ipv4_address",
        "domain_var": "infisical_domain",
        "tf_domain": "infisical_server_name",
        "user_var": "onramp_host_deploy_user",
        "tf_user": "onramp_host_deploy_user",
        "extra_play_vars": {
          "onramp_host_deploy_dir": "onramp_host_deploy_dir",
          "infisical_container_port": "infisical_container_port",
          "infisical_bind_address": "infisical_bind_address"
        }
      }
    },
    "hermes": {
      "state_capable": true,
      "state_order": 1,
      "terraform_addresses": [
        "module.hermes[",
        "module.hermes_vm["
      ],
      "terraform_replace_addresses": {
        "lxc": ["module.hermes[0].proxmox_virtual_environment_container.this"],
        "vm": ["module.hermes_vm[0].proxmox_virtual_environment_vm.this"]
      },
      "playbooks": [
        "infra/ansible/playbooks/hermes.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "hermes_lxc",
        "group": "hermes",
        "vmid_var": "hermes_vmid",
        "tf_vmid": "hermes_container_vmid",
        "tf_host": "hermes_lan_ip",
        "domain_var": "hermes_domain",
        "tf_domain": "hermes_server_name",
        "tf_user": "hermes_ansible_user",
        "extra_play_vars": {
          "hermes_runtime_user": "hermes_runtime_user",
          "hermes_ssh_public_keys": "lxc_ssh_public_keys"
        }
      }
    },
    "onramp_host": {
      "state_capable": true,
      "state_order": 4,
      "terraform_addresses": [
        "proxmox_virtual_environment_vm.onramp_host["
      ],
      "playbooks": [
        "infra/ansible/playbooks/onramp-host.yml"
      ],
      "dependencies": [],
      "inventory": {
        "host": "onramp_host_vm",
        "group": "onramp_host",
        "vmid_var": "onramp_host_vmid",
        "tf_vmid": "onramp_host_vmid",
        "tf_host": "onramp_host_ipv4_address",
        "domain_var": "onramp_host_hostname",
        "tf_domain": "onramp_host_hostname",
        "user_var": "onramp_host_deploy_user",
        "tf_user": "onramp_host_deploy_user",
        "extra_play_vars": {
          "onramp_host_cloud_init_user": "onramp_host_cloud_init_user",
          "onramp_host_deploy_dir": "onramp_host_deploy_dir",
          "onramp_host_ssh_public_keys": "onramp_host_ssh_public_keys",
          "onramp_host_password_authentication": "onramp_host_password_authentication",
          "onramp_host_permit_root_login": "onramp_host_permit_root_login",
          "onramp_host_allow_passwordless_sudo": "onramp_host_allow_passwordless_sudo",
          "onramp_host_allowed_ssh_cidrs": "onramp_host_allowed_ssh_cidrs"
        }
      }
    },
    "searxng_onramp": {
      "state_capable": true,
      "state_order": 6,
      "terraform_addresses": [
        "proxmox_virtual_environment_vm.onramp_host["
      ],
      "playbooks": [
        "infra/ansible/playbooks/searxng-onramp.yml"
      ],
      "dependencies": [
        "onramp_host"
      ],
      "inventory": {
        "host": "onramp_host_vm",
        "group": "onramp_host",
        "vmid_var": "onramp_host_vmid",
        "tf_vmid": "onramp_host_vmid",
        "tf_host": "onramp_host_ipv4_address",
        "domain_var": "onramp_host_hostname",
        "tf_domain": "onramp_host_hostname",
        "user_var": "onramp_host_deploy_user",
        "tf_user": "onramp_host_deploy_user",
        "extra_play_vars": {
          "onramp_host_deploy_dir": "onramp_host_deploy_dir",
          "searxng_server_name": "searxng_server_name",
          "searxng_public_url": "searxng_public_url",
          "searxng_container_image": "searxng_container_image",
          "searxng_container_port": "searxng_container_port",
          "searxng_bind_address": "searxng_bind_address",
          "searxng_instance_name": "searxng_instance_name",
          "searxng_enable_public_url": "searxng_enable_public_url"
        }
      }
    }
  }
}
