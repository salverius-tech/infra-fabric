# Copy to values/.env and fill in local secrets.

export PROXMOX_VE_ENDPOINT="https://proxmox.example.internal:8006/"
export PROXMOX_VE_API_TOKEN="terraform@pve!provider=REPLACE_WITH_PROXMOX_TOKEN"

# SSH/bootstrap target.
export PVE_HOST="proxmox.example.internal"

# Cloudflare credentials used by Caddy DNS-01.
export CF_API_EMAIL="admin@example.internal"
export CF_DNS_API_TOKEN="REPLACE_WITH_CLOUDFLARE_DNS_TOKEN"

# Used as Terraform variables for LXC root accounts.
export TF_VAR_lxc_root_password="REPLACE_WITH_A_LONG_RANDOM_PASSWORD"
export TF_VAR_lxc_ssh_public_keys='["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA_REPLACE_ME user@host"]'

# Technitium API settings for DNS management after service setup.
export TECHNITIUM_API_URL="https://dns.example.internal/api"
export TECHNITIUM_API_TOKEN="REPLACE_AFTER_TOKEN_CREATION"
export DNS_RECORDS_FILE="values/dns-records.local.json"

# Forgejo Actions runner offline registration secret. Generate 40 hex characters.
export FORGEJO_RUNNER_REGISTRATION_SECRET="REPLACE_WITH_40_HEX_CHARACTERS"

# Infisical bootstrap secrets. Keep these in the private values repo or break-glass store.
export INFISICAL_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_HEX_KEY"
export INFISICAL_AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_AUTH_SECRET"
export INFISICAL_POSTGRES_PASSWORD="REPLACE_WITH_LONG_RANDOM_DB_PASSWORD"
