# Copy to values/.env and fill in local secrets.

export PROXMOX_VE_ENDPOINT="https://proxmox.example.internal:8006/"
export PROXMOX_VE_API_TOKEN="terraform@pve!provider=REPLACE_WITH_PROXMOX_TOKEN"

# SSH/bootstrap target.
export PVE_HOST="proxmox.example.internal"

# Optional EdgeRouter read-only SSH access. Use key-based authentication only.
export EDGEROUTER_ADDR="firewall.example.internal"
export EDGEROUTER_USER="ubnt"
# Do not store EDGEROUTER_PASS; the EdgeRouter account must have read-only access.

# Cloudflare credentials used by Caddy DNS-01.
export CF_API_EMAIL="admin@example.internal"
export CF_DNS_API_TOKEN="REPLACE_WITH_CLOUDFLARE_DNS_TOKEN"

# Used as Terraform variables for LXC root accounts.
export TF_VAR_lxc_root_password="REPLACE_WITH_A_LONG_RANDOM_PASSWORD"
export TF_VAR_lxc_ssh_public_keys='["ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA_REPLACE_ME user@host"]'

# Technitium API settings for DNS management after service setup.
export TECHNITIUM_API_URL="http://192.0.2.53:5380/api"
export TECHNITIUM_API_TOKEN="REPLACE_AFTER_TOKEN_CREATION"
export TECHNITIUM_ADMIN_USER="admin"
export TECHNITIUM_ADMIN_PASSWORD="REPLACE_AFTER_FIRST_APPLY"
export DNS_RECORDS_FILE="values/dns-records.local.json"

# Forgejo persistent security secrets and Actions runner offline registration secret.
export FORGEJO_SECRET_KEY="REPLACE_WITH_LONG_RANDOM_FORGEJO_SECRET_KEY"
export FORGEJO_INTERNAL_TOKEN="REPLACE_WITH_LONG_RANDOM_FORGEJO_INTERNAL_TOKEN"
export FORGEJO_OAUTH2_JWT_SECRET="REPLACE_WITH_LONG_RANDOM_FORGEJO_OAUTH2_JWT_SECRET"
export FORGEJO_LFS_JWT_SECRET="REPLACE_WITH_LONG_RANDOM_FORGEJO_LFS_JWT_SECRET"
export FORGEJO_RUNNER_REGISTRATION_SECRET="REPLACE_WITH_40_HEX_CHARACTERS"

# Infisical bootstrap secrets. Keep these in the private values repo or break-glass store.
export INFISICAL_ENCRYPTION_KEY="REPLACE_WITH_16_BYTE_HEX_KEY"
export INFISICAL_AUTH_SECRET="REPLACE_WITH_LONG_RANDOM_AUTH_SECRET"
export INFISICAL_POSTGRES_PASSWORD="REPLACE_WITH_LONG_RANDOM_DB_PASSWORD"

# Hermes Agent dashboard basic-auth settings. Generate the hash with:
# python scripts/hermes-password-hash.py
export HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH="REPLACE_WITH_HERMES_SCRYPT_PASSWORD_HASH"
export HERMES_DASHBOARD_BASIC_AUTH_SECRET="REPLACE_WITH_32_BYTE_RANDOM_SECRET"

# SearXNG onramp workload secret and Hermes web search endpoint.
export SEARXNG_SECRET_KEY="REPLACE_WITH_LONG_RANDOM_SEARXNG_SECRET"
export HERMES_WEB_SEARXNG_URL="https://searxng.apps.example.net"
